{
  "name": "world3-web",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc -p tsconfig.cli.json",
    "browser-native:cli": "node js/cli/browser-native-cli.js",
    "serve": "node js/cli/static-server.js",
    "test:e2e": "playwright test",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.cli.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "typecheck:src": "tsc -p tsconfig.json --noEmit",
    "typecheck:cli": "tsc -p tsconfig.cli.json --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "lint:locales": "node scripts/check-locales.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.5.2",
    "@vitest/coverage-v8": "^4.1.2",
    "jsdom": "^29.0.1",
    "typescript": "^5.8.2",
    "vitest": "^4.1.2"
  }
}
